<configuration>
    <appender name="JSON_CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>{"timestamp":"%d{yyyy-MM-dd'T'HH:mm:ss.SSSXXX}","level":"%level","service":"transaction-service","logger":"%logger{36}","thread":"%thread","message":"%replace(%msg){'&quot;','\\&quot;'}"}%n</pattern>
        </encoder>
    </appender>

    <root level="${LOG_LEVEL:-INFO}">
        <appender-ref ref="JSON_CONSOLE"/>
    </root>
</configuration>
