.claude/
 # Environment files
  .env
  .env.*
  !.env.example

  # Node / frontend
  node_modules/
  dist/
  build/
  .vite/
  npm-debug.log*
  yarn-debug.log*
  yarn-error.log*
  pnpm-debug.log*

  # Python
  __pycache__/
  *.py[cod]
  *.pyo
  *.pyd
  .venv/
  venv/
  env/
  .pytest_cache/
  .mypy_cache/
  .coverage
  htmlcov/

  # Java / Maven
  target/
  *.class
  *.jar
  *.war
  *.ear

  # IDE / editors
  .vscode/
  .idea/
  *.swp
  *.swo

  # OS files
  .DS_Store
  Thumbs.db

  # Logs
  *.log
  logs/

  # Docker / local runtime
  docker-compose.override.yml

  # Temporary Office lock files
  ~$*.docx
  ~$*.pptx

  # Terraform, if used later
  .terraform/
  *.tfstate
  *.tfstate.*
  .terraform.lock.hcl

  # Kubernetes generated local files
  kubeconfig*
  *.kubeconfig

  # Screenshots/videos raw local drafts
  *.webm
  *.mp4