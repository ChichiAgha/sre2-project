 # PostgreSQL
  POSTGRES_DB=<database-name>
  POSTGRES_USER=<database-username>
  POSTGRES_PASSWORD=<database-password>

  # Python services
  DATABASE_URL=postgresql://<database-username>:<database-password>@<postgres-host>:<postgres-port>/<database-name>

  # Spring transaction service
  SPRING_DATASOURCE_URL=jdbc:postgresql://<postgres-host>:<postgres-port>/<database-name>
  SPRING_DATASOURCE_USERNAME=<database-username>
  SPRING_DATASOURCE_PASSWORD=<database-password>
  SPRING_JPA_HIBERNATE_DDL_AUTO=<hibernate-ddl-mode>
  SERVER_PORT=<transaction-service-port>

  # Kafka
  KAFKA_BOOTSTRAP_SERVERS=<kafka-host>:<kafka-port>

  # Redis
  REDIS_HOST=<redis-host>
  REDIS_PORT=<redis-port>

  # CORS
  FRONTEND_ORIGIN=<frontend-origin-url>